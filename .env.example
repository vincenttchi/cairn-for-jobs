# Copy this file to .env and fill in your own key(s).
# Never commit your real .env file — it's already in .gitignore.
#
# You only need one of these, depending on which provider you use.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Path to your Obsidian vault's Applications folder, so the app tracker
# agent knows where to write new job entry notes.
VAULT_APPLICATIONS_PATH=./vault-template/Applications
